.page { min-height: 100vh; overflow-y: auto; -webkit-overflow-scrolling: touch; padding-bottom: 160rpx; }

.page-header {
  padding: 32rpx 24rpx 16rpx;
}
.page-title { font-size: 36rpx; font-weight: 700; color: #1a1a2e; }
.page-subtitle { font-size: 26rpx; color: #999; margin-top: 8rpx; display: block; }

/* 卡片 */
.card {
  background: #fff; margin: 16rpx; padding: 24rpx;
  border-radius: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.section-title {
  font-size: 30rpx; font-weight: 600; color: #1a1a2e;
  padding-bottom: 16rpx; border-bottom: 2rpx solid #f0f0f0; margin-bottom: 20rpx;
}

/* 拍照网格 */
.photo-grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 12rpx;
}
.photo-item { aspect-ratio: 4/3; }
.photo-wrapper {
  width: 100%; height: 100%; border-radius: 12rpx; overflow: hidden; position: relative;
}
.photo-img { width: 100%; height: 100%; }
.photo-remove {
  position: absolute; top: 4rpx; right: 4rpx;
  width: 36rpx; height: 36rpx; border-radius: 50%;
  background: rgba(0,0,0,0.5); color: #fff; font-size: 28rpx;
  display: flex; align-items: center; justify-content: center;
}
.photo-placeholder {
  width: 100%; height: 100%; border: 2rpx dashed #ddd; border-radius: 12rpx;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  background: #fafafa;
}
.photo-icon { font-size: 40rpx; }
.photo-label { font-size: 20rpx; color: #999; margin-top: 6rpx; }

/* 表单 */
.form-group {
  margin-bottom: 24rpx;
}
.form-label {
  display: block; font-size: 26rpx; color: #666; margin-bottom: 10rpx;
}
.input-field {
  width: 100%; padding: 16rpx 20rpx; border: 2rpx solid #eee;
  border-radius: 12rpx; font-size: 28rpx; box-sizing: border-box;
}
.textarea-field {
  width: 100%; padding: 16rpx 20rpx; border: 2rpx solid #eee;
  border-radius: 12rpx; font-size: 28rpx; min-height: 160rpx; box-sizing: border-box;
}
.picker {
  width: 100%; padding: 16rpx 20rpx; border: 2rpx solid #eee;
  border-radius: 12rpx; font-size: 28rpx; box-sizing: border-box;
}
.picker-value { color: #333; }

/* 底部提交 */
.form-footer {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 16rpx 24rpx 32rpx; background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.04);
}
.btn-primary {
  width: 100%; height: 88rpx; border-radius: 44rpx;
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  color: #fff; font-size: 30rpx; font-weight: 600;
  display: flex; align-items: center; justify-content: center;
}
.btn-primary[disabled] { opacity: 0.5; }
