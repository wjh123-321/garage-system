.page { min-height: 100vh; overflow-y: auto; -webkit-overflow-scrolling: touch; padding-bottom: 120rpx; }

.page-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 24rpx 32rpx 16rpx;
}
.page-title { font-size: 36rpx; font-weight: 700; color: #1a1a2e; }
.send-all-btn {
  padding: 12rpx 28rpx; border-radius: 40rpx; font-size: 24rpx;
  background: #1a1a2e; color: #fff;
}

.notification-card {
  background: #fff; margin: 16rpx 32rpx; padding: 24rpx;
  border-radius: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.notification-card.sent { opacity: 0.6; }

.card-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.type-tag { font-size: 26rpx; font-weight: 600; color: #1a1a2e; }
.status-badge { padding: 4rpx 16rpx; border-radius: 8rpx; font-size: 22rpx; }
.status-badge.pending { background: #fff3e0; color: #e65100; }
.status-badge.sent { background: #e8f5e9; color: #2e7d32; }

.card-body { padding: 8rpx 0; }
.info-row { display: flex; align-items: center; padding: 4rpx 0; font-size: 26rpx; }
.info-row .label { color: #999; width: 80rpx; flex-shrink: 0; }
.plate { font-weight: 600; color: #1a1a2e; letter-spacing: 2rpx; }

.msg-preview {
  margin-top: 12rpx; padding: 16rpx; background: #fafafa;
  border-radius: 12rpx; font-size: 24rpx; color: #666; line-height: 1.6;
}

.card-footer {
  display: flex; justify-content: space-between; align-items: center;
  margin-top: 16rpx; padding-top: 16rpx; border-top: 2rpx solid #f5f5f5;
}
.time { font-size: 22rpx; color: #bbb; }
.sent-btn {
  padding: 8rpx 24rpx; border-radius: 40rpx; font-size: 24rpx;
  background: #e3f2fd; color: #1565c0;
}
.sent-btn.disabled { background: #f5f5f5; color: #bbb; }

.empty-state {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center; padding: 200rpx 0;
}
.empty-icon { font-size: 96rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: #ccc; }

.loading { text-align: center; padding: 40rpx; font-size: 26rpx; color: #999; }
