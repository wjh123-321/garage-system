.page { min-height: 100vh; overflow-y: auto; -webkit-overflow-scrolling: touch; padding-bottom: 40rpx; }
.vin-title { font-size: 36rpx; font-weight: 700; text-align: center; margin-bottom: 8rpx; }
.vin-desc { display: block; font-size: 26rpx; color: #888; text-align: center; margin-bottom: 32rpx; }
.vin-input-area { position: relative; text-align: center; margin-bottom: 24rpx; }
.vin-input {
  display: inline-block; background: #f0f4ff; border: 4rpx solid #1a1a2e;
  border-radius: 16rpx; padding: 24rpx 48rpx; font-size: 56rpx; font-weight: 700;
  text-align: center; letter-spacing: 8rpx; width: 80%; text-transform: uppercase;
}
.vin-count { display: block; font-size: 22rpx; color: #aaa; text-align: center; margin-top: 8rpx; }
.btn-primary {
  display: block; width: 80%; margin: 0 auto; background: #1a1a2e; color: #fff;
  border-radius: 12rpx; padding: 24rpx 0; text-align: center; font-size: 30rpx; font-weight: 600;
}
.btn-primary[disabled] { opacity: 0.5; }
.section-title { font-size: 30rpx; font-weight: 600; margin-bottom: 16rpx; }

/* 结果卡片 */
.result-card { margin-top: 20rpx; }
.vin-badge {
  background: #eef2ff; color: #1a1a2e; font-size: 24rpx; font-weight: 600;
  padding: 12rpx 20rpx; border-radius: 8rpx; margin-bottom: 24rpx; text-align: center;
  word-break: break-all;
}

/* 信息网格 */
.info-grid { display: flex; flex-wrap: wrap; gap: 0; }
.info-item {
  width: 50%; padding: 20rpx 16rpx; box-sizing: border-box;
  border-bottom: 2rpx solid #f5f5f5;
}
.info-item:nth-last-child(-n+2) { border-bottom: none; }
.info-label { display: block; font-size: 24rpx; color: #999; margin-bottom: 6rpx; }
.info-value { display: block; font-size: 28rpx; font-weight: 500; color: #333; }

/* 额外区块 */
.extra-section { margin-top: 24rpx; padding-top: 24rpx; border-top: 2rpx solid #f0f0f0; }

/* 错误状态 */
.error-state { display: flex; flex-direction: column; align-items: center; padding: 40rpx 0; }
.error-icon {
  display: flex; align-items: center; justify-content: center;
  width: 80rpx; height: 80rpx; border-radius: 50%; background: #fee2e2;
  font-size: 40rpx; font-weight: 700; color: #dc2626; margin-bottom: 16rpx;
}
.error-text { font-size: 28rpx; color: #dc2626; }

/* 空状态 */
.empty-state { text-align: center; padding: 60rpx 0; color: #999; font-size: 28rpx; }

/* 查询历史 */
.history-item {
  padding: 20rpx 0; border-bottom: 2rpx solid #f5f5f5;
}
.history-item:last-child { border-bottom: none; }
.history-vin {
  font-size: 28rpx; font-weight: 500; color: #1a1a2e; font-family: monospace;
}
