.page {
  padding: 16px;
  min-height: 100vh;
  background: #f5f5f5;
}

.loading {
  text-align: center;
  padding: 40px 0;
  color: #999;
  font-size: 14px;
}

.card {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #333;
  margin-bottom: 14px;
}

/* 对比网格 */
.compare-grid {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.compare-col {
  flex: 1;
  text-align: center;
}

.period-label {
  display: block;
  font-size: 13px;
  color: #888;
  margin-bottom: 6px;
}

.amount {
  display: block;
  font-size: 22px;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 4px;
}

.sub {
  display: block;
  font-size: 12px;
  color: #999;
  margin-top: 2px;
}

.vs {
  margin: 0 12px;
  font-size: 12px;
  color: #ccc;
  font-weight: 600;
}

/* 变化率 */
.change-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px solid #f0f0f0;
}

.change-row:last-child {
  border-bottom: none;
}

.change-label {
  font-size: 14px;
  color: #666;
}

.change-value {
  font-size: 15px;
  font-weight: 600;
}

.change-value.up {
  color: #22c55e;
}

.change-value.down {
  color: #ef4444;
}
