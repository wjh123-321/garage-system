<view class="page">
  <view class="card" style="text-align:center;padding:60rpx">
    <button class="btn-primary" bindtap="chooseImage">📷 拍照识别故障</button>
  </view>
  <view wx:if="{{imageSrc}}" class="card">
    <image src="{{imageSrc}}" style="width:100%;height:400rpx" mode="aspectFit"/>
  </view>
  <view wx:if="{{loading}}" class="loading">AI分析中...</view>
  <view wx:if="{{result}}" class="card">
    <view class="section-title">识别结果</view>
    <text>{{result.description||'暂无结果'}}</text>
  </view>
</view>
