.page { min-height: 100vh; overflow-y: auto; -webkit-overflow-scrolling: touch; padding-bottom: 40rpx; }

/* 统计卡片 */
.stats-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 16rpx;
  gap: 16rpx;
}
.stat-card {
  flex: 1;
  min-width: calc(50% - 24rpx);
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.stat-num { font-size: 44rpx; font-weight: 700; color: #1a1a2e; display: block; }
.stat-num.running { color: #2e7d32; }
.stat-num.maintenance { color: #e65100; }
.stat-num.expense { color: #1565c0; font-size: 36rpx; }
.stat-label { font-size: 22rpx; color: #999; margin-top: 8rpx; display: block; }

/* 待办事项 */
.todo-list { }
.todo-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}
.todo-item:last-child { border-bottom: none; }
.todo-left { display: flex; align-items: center; gap: 20rpx; flex: 1; }
.todo-icon { font-size: 40rpx; width: 56rpx; text-align: center; }
.todo-info { display: flex; flex-direction: column; }
.todo-title { font-size: 28rpx; font-weight: 600; color: #333; }
.todo-desc { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.todo-right { display: flex; align-items: center; gap: 12rpx; }
.todo-count {
  font-size: 36rpx; font-weight: 700; color: #1a1a2e;
  min-width: 48rpx; text-align: center;
}
.todo-arrow { font-size: 28rpx; color: #ccc; }

/* 状态图例 */
.legend {
  display: flex;
  gap: 32rpx;
  padding-bottom: 20rpx;
  margin-bottom: 8rpx;
  border-bottom: 2rpx solid #f5f5f5;
}
.legend-item { display: flex; align-items: center; gap: 10rpx; font-size: 24rpx; color: #666; }
.legend-dot { width: 16rpx; height: 16rpx; border-radius: 50%; }
.dot-running { background: #2e7d32; }
.dot-maintenance { background: #e65100; }
.dot-stopped { background: #9e9e9e; }

/* 车辆列表 */
.section-title {
  font-size: 32rpx; font-weight: 600; margin-bottom: 24rpx;
  display: flex; justify-content: space-between; align-items: center;
}
.section-subtitle { font-size: 24rpx; font-weight: 400; color: #999; }

.vehicle-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
  gap: 16rpx;
}
.vehicle-item:last-child { border-bottom: none; }
.vehicle-status-indicator {
  width: 8rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
}
.vehicle-content { flex: 1; min-width: 0; }
.vehicle-top { display: flex; justify-content: space-between; align-items: center; }
.vehicle-plate { font-size: 30rpx; font-weight: 700; color: #1a1a2e; }
.vehicle-badge {
  font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 8rpx;
  font-weight: 500;
}
.badge-running { background: #e8f5e9; color: #2e7d32; }
.badge-maintenance { background: #fff3e0; color: #e65100; }
.badge-stopped { background: #f5f5f5; color: #9e9e9e; }
.vehicle-info { font-size: 24rpx; color: #666; margin-top: 8rpx; display: flex; align-items: center; gap: 12rpx; }
.vehicle-divider { color: #ddd; }
.vehicle-mileage { font-size: 22rpx; color: #999; margin-top: 4rpx; }

/* 通用 */
.loading { text-align: center; padding: 60rpx 0; color: #999; }
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.empty-state { text-align: center; padding: 60rpx 40rpx; color: #999; font-size: 28rpx; }
