<view class="page">

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <block wx:else>

    <!-- 统计卡片 -->
    <view class="stats-grid">
      <view class="stat-card">
        <text class="stat-num">{{stats.totalVehicles}}</text>
        <text class="stat-label">总车辆</text>
      </view>
      <view class="stat-card">
        <text class="stat-num running">{{stats.runningCount}}</text>
        <text class="stat-label">运行中</text>
      </view>
      <view class="stat-card">
        <text class="stat-num maintenance">{{stats.maintenanceCount}}</text>
        <text class="stat-label">维修中</text>
      </view>
      <view class="stat-card" bindtap="goExpense">
        <text class="stat-num expense">{{stats._monthlyExpenseDisplay}}</text>
        <text class="stat-label">本月支出(元)</text>
      </view>
    </view>

    <!-- 待办事项 -->
    <view class="card">
      <view class="section-title">待办事项</view>
      <view class="todo-list">
        <view class="todo-item" bindtap="goTodo" data-type="maintenance">
          <view class="todo-left">
            <text class="todo-icon icon-maintenance">🔧</text>
            <view class="todo-info">
              <text class="todo-title">待保养车辆</text>
              <text class="todo-desc">即将到达保养里程/时间</text>
            </view>
          </view>
          <view class="todo-right">
            <text class="todo-count">{{todos.maintenanceDue}}</text>
            <text class="todo-arrow">→</text>
          </view>
        </view>
        <view class="todo-item" bindtap="goTodo" data-type="inspection">
          <view class="todo-left">
            <text class="todo-icon icon-inspection">📋</text>
            <view class="todo-info">
              <text class="todo-title">年检到期</text>
              <text class="todo-desc">本月需完成年检审核</text>
            </view>
          </view>
          <view class="todo-right">
            <text class="todo-count">{{todos.inspectionDue}}</text>
            <text class="todo-arrow">→</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 车辆状态概览 -->
    <view class="card">
      <view class="section-title">
        <text>车辆状态概览</text>
        <text class="section-subtitle">{{vehicles.length}}辆车</text>
      </view>

      <!-- 状态图例 -->
      <view class="legend">
        <view class="legend-item">
          <view class="legend-dot dot-running"></view>
          <text>运行中</text>
        </view>
        <view class="legend-item">
          <view class="legend-dot dot-maintenance"></view>
          <text>维修中</text>
        </view>
        <view class="legend-item">
          <view class="legend-dot dot-stopped"></view>
          <text>停运</text>
        </view>
      </view>

      <!-- 车辆列表 -->
      <view wx:if="{{vehicles.length === 0}}" class="empty-state">暂无车辆数据</view>

      <view wx:for="{{vehicles}}" wx:key="id" class="vehicle-item" bindtap="goVehicleDetail" data-id="{{item.id}}">
        <view class="vehicle-status-indicator" style="background:{{item._statusColor}}"></view>
        <view class="vehicle-content">
          <view class="vehicle-top">
            <text class="vehicle-plate">{{item.plate}}</text>
            <text class="vehicle-badge badge-{{item._statusClass}}">{{item._statusLabel}}</text>
          </view>
          <view class="vehicle-info">
            <text>{{item.brand}}</text>
            <text class="vehicle-divider">|</text>
            <text>司机: {{item.driver}}</text>
          </view>
          <view class="vehicle-mileage">
            <text>里程: {{item._mileageDisplay}}</text>
          </view>
        </view>
      </view>
    </view>

  </block>

</view>
