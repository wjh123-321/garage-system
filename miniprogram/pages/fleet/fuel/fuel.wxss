.page {
  min-height: 100vh;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding-bottom: 80rpx;
}

/* ===== 汇总卡片 ===== */
.summary-card {
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  border-radius: 24rpx;
  margin: 24rpx 24rpx 0;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(26, 26, 46, 0.25);
}
.summary-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}
.summary-title {
  font-size: 30rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.85);
}
.vehicle-picker {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.12);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
}
.vehicle-text {
  font-size: 26rpx;
  color: #fff;
}
.vehicle-arrow {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
}
.summary-grid {
  display: flex;
  gap: 16rpx;
}
.summary-item {
  flex: 1;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  padding: 20rpx 16rpx;
  text-align: center;
}
.summary-item.highlight {
  background: rgba(255, 183, 77, 0.2);
  border: 2rpx solid rgba(255, 183, 77, 0.35);
}
.summary-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 6rpx;
}
.summary-item.highlight .summary-num {
  color: #ffb74d;
}
.summary-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  display: block;
}

/* ===== 添加栏 ===== */
.add-bar {
  margin: 24rpx 24rpx 0;
}
.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: #fff;
  border: 2rpx dashed #ccc;
  border-radius: 20rpx;
  padding: 28rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.2s;
}
.add-btn:active {
  border-color: #1a1a2e;
  color: #1a1a2e;
  background: #f8f8ff;
}
.add-icon {
  font-size: 36rpx;
  font-weight: 300;
  color: #1a1a2e;
}

/* ===== 遮罩 + 表单 ===== */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 99;
}
.form-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 32rpx 60rpx;
  z-index: 100;
  max-height: 75vh;
  overflow-y: auto;
  animation: slideUp 0.25s ease-out;
}
@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
.form-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 32rpx;
  text-align: center;
}
.form-group {
  margin-bottom: 24rpx;
}
.form-label {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 10rpx;
  font-weight: 500;
}
.form-input {
  width: 100%;
  box-sizing: border-box;
  height: 88rpx;
  line-height: 88rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333;
  border: none;
  outline: none;
}
.form-input:focus,
.form-input.focus {
  background: #f0f0ff;
  box-shadow: 0 0 0 2rpx rgba(26, 26, 46, 0.15);
}
.picker-text {
  color: #999;
}
.form-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}
.form-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
}
.form-btn.cancel {
  background: #f0f0f0;
  color: #666;
}
.form-btn.submit {
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  color: #fff;
}
.form-btn.submit:active {
  opacity: 0.85;
}

/* ===== 列表标题 ===== */
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin: 32rpx 24rpx 16rpx;
}

/* ===== 记录项 ===== */
.record-item {
  background: #fff;
  border-radius: 20rpx;
  margin: 0 24rpx 16rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
.record-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.record-date {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}
.record-station {
  font-size: 24rpx;
  color: #999;
  background: #f5f5f5;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}
.record-details {
  display: flex;
  gap: 8rpx;
}
.record-field {
  flex: 1;
  text-align: center;
  background: #fafafa;
  border-radius: 12rpx;
  padding: 14rpx 8rpx;
}
.field-label {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 4rpx;
}
.field-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
}
.field-value.cost {
  color: #e65100;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
  color: #ccc;
  font-size: 28rpx;
}
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}
.empty-hint {
  font-size: 24rpx;
  color: #ddd;
  margin-top: 12rpx;
}

/* ===== 加载 ===== */
.loading {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 26rpx;
}
