.page {
  min-height: 100vh;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding-bottom: 160rpx;
}

/* 搜索区 */
.search-area {
  padding-bottom: 20rpx;
}

/* 面包屑 */
.breadcrumb {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}
.breadcrumb-link {
  color: #1a1a2e;
  font-weight: 500;
}
.breadcrumb-link:active {
  opacity: 0.6;
}
.breadcrumb-sep {
  margin: 0 8rpx;
  color: #ccc;
}
.breadcrumb-item {
  color: #666;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 列表项 */
.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}
.list-item:last-child {
  border-bottom: none;
}
.list-item:active {
  opacity: 0.7;
}
.list-item-text {
  font-size: 28rpx;
  color: #333;
}
.list-item-arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 分类标题 */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 8rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

/* 配件卡片 */
.part-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}
.part-arrow {
  font-size: 28rpx;
  color: #ccc;
}
.part-meta {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 12rpx;
  font-size: 24rpx;
}
.part-oe {
  color: #1565c0;
  background: #e3f2fd;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.part-price {
  color: #e65100;
  font-weight: 500;
}

/* 详情 */
.detail-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a2e;
  flex: 1;
}
.detail-back {
  font-size: 26rpx;
  color: #1a1a2e;
  font-weight: 500;
  padding: 8rpx 16rpx;
}
.detail-back:active {
  opacity: 0.6;
}
.detail-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}
.detail-row:last-child {
  border-bottom: none;
}
.detail-label {
  width: 160rpx;
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
}
.detail-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}
.detail-price {
  font-size: 34rpx;
  font-weight: 700;
  color: #e65100;
}

/* 底部操作 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 32rpx 32rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
  text-align: center;
}
.btn-vin {
  width: 100%;
  font-size: 30rpx;
  padding: 28rpx 0;
}
.vin-manual {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999;
  text-decoration: underline;
}
.vin-manual:active {
  opacity: 0.6;
}
