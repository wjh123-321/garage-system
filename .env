# ⚠️ 本地开发配置 — Zeabur 部署时无需此文件
# Zeabur 会自动通过环境变量注入数据库连接

APP_NAME=汽修智能管理系统
APP_VERSION=0.1.0
DEBUG=false

# ⚠️ 以下配置在 Zeabur 控制台设置
# 连接 Zeabur PostgreSQL 插件后会自动注入：
# DB_HOST, DB_PORT, DB_USER, DB_PASSWORD, DB_NAME

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=garage_system

# 火山引擎方舟AI（保持不变）
VOLC_ARK_API_KEY=ark-1b134190-ce8b-4aba-a0f7-b349445b8c2c-c8e9a
VOLC_ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLC_ARK_MODEL=doubao-pro-32k-250528
AI_ENABLED=true
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=4096
